# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks sh/bash in Linux containers
*.sh text eol=lf

# Windows-only files can stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries: no line-ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
